# ============================================================
# Azkali Mobile — Variables de entorno
# ============================================================
# Copia este archivo como .env y rellena los valores reales:
#   cp .env.example .env
#
# Los valores locales los genera `supabase start` automáticamente.
# Para verlos en cualquier momento corre: supabase status
# ============================================================


# ── Supabase local (desarrollo) ─────────────────────────────
#
# EXPO_PUBLIC_SUPABASE_URL
#   Origen: output de `supabase start` → campo "Project URL"
#   En local siempre es http://127.0.0.1:54321
EXPO_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321

# EXPO_PUBLIC_SUPABASE_ANON_KEY
#   Origen: output de `supabase start` → campo "Publishable" (Authentication Keys)
#   Es la clave pública segura para usar desde el cliente (Expo/React Native).
#   Respeta las políticas de Row Level Security (RLS) de Supabase.
EXPO_PUBLIC_SUPABASE_ANON_KEY=<anon-key-del-supabase-start>

# SUPABASE_SERVICE_ROLE_KEY
#   Origen: output de `supabase start` → campo "Secret" (Authentication Keys)
#   ⚠️  Clave con permisos completos. Bypasea RLS.
#   Úsala SOLO en el servidor o scripts de administración. Nunca en el cliente.
SUPABASE_SERVICE_ROLE_KEY=<service-role-key-del-supabase-start>


# ── Supabase producción (solo en CI/CD o entorno de prod) ───
#
# Los valores de producción se obtienen desde:
# https://supabase.com/dashboard → tu proyecto → Settings → API
#
# EXPO_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
# EXPO_PUBLIC_SUPABASE_ANON_KEY=<produccion-anon-key>
# SUPABASE_SERVICE_ROLE_KEY=<produccion-service-role-key>
